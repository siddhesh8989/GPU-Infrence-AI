# ─── GPU Inference Pipeline — Local Setup ─────────────────────────────────────
#
# To run locally:
#   1. Copy this file:   cp .env.example .env
#   2. Open .env and paste your Groq key (free at https://console.groq.com)
#   3. Start both services:
#       Terminal 1:  cd artifacts/gpu-inference && python app.py
#       Terminal 2:  cd artifacts/api-server    && pnpm run dev
#
# Both services automatically load .env from the project root.
# On Replit: set GROQ_API_KEY in the Secrets panel instead of this file.
# ──────────────────────────────────────────────────────────────────────────────

GROQ_API_KEY=paste_your_groq_api_key_here
